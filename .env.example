# XTJS 后端环境变量示例
# 复制为 .env 后按需修改。docker compose 会自动读取本目录的 .env 做变量替换，
# 本地直跑（python run.py）时 pydantic-settings 也会读取 .env。
# 说明：OCR/缓存等其余变量已在 docker-compose.yml 内置默认值，按需覆盖即可，
#       此处仅列出认证功能新增的关键项。

# —— 认证与账号安全 ——
# JWT 签名密钥：生产环境务必改成一段足够长的随机串（如 `openssl rand -hex 32` 生成），切勿沿用默认值。
JWT_SECRET_KEY=please-change-to-a-long-random-secret
JWT_ALGORITHM=HS256
# 访问令牌有效期（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
# 连续登录失败达到该次数后锁定账号
AUTH_MAX_FAILED_ATTEMPTS=5
# 账号锁定时长（分钟）
AUTH_LOCK_MINUTES=15
# 新密码/重置密码的最小长度（同时要求字母+数字）
AUTH_PASSWORD_MIN_LENGTH=8

# —— 初始管理员（首次启动自动创建，用于引导首个账号）——
# 留空 AUTH_INITIAL_ADMIN_PASSWORD 则不创建；创建后建议尽快登录并修改密码。
AUTH_INITIAL_ADMIN_USERNAME=admin
AUTH_INITIAL_ADMIN_PASSWORD=

# —— 数据库（如需覆盖 compose 默认值）——
# DATABASE_URL=postgresql://admin:password@postgres:5432/xtjs_db
