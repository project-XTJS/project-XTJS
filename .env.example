# Docker compose runtime settings
DATABASE_URL=postgresql://admin:password@postgres:5432/xtjs_db

# MinIO runtime settings
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=tendering-files
MINIO_SECURE=false
MINIO_PRESIGNED_EXPIRES_DAYS=7
MINIO_MAX_FILE_SIZE=524288000
MINIO_ALLOWED_EXTENSIONS=pdf,docx,doc

# PaddleOCR 3.x runtime settings
OCR_STORAGE_ROOT=E:\xtjs-ocr
PADDLE_PDX_CACHE_HOME=E:\xtjs-ocr\paddlex-cache-v2
OCR_RUNTIME_TEMP_DIR=E:\xtjs-ocr\runtime-tmp
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=true
PADDLE_OCR_DEVICE=cpu
PADDLE_OCR_FALLBACK_TO_CPU=true
PADDLE_OCR_DISABLE_MKLDNN=true
PADDLE_OCR_LANG=ch
PADDLE_OCR_VERSION=PP-OCRv5
PADDLE_OCR_ENABLE_HPI=false
PADDLE_OCR_ENABLE_STRUCTURE=true
PADDLE_OCR_USE_DOC_ORIENTATION=true
PADDLE_OCR_USE_DOC_UNWARPING=true
PADDLE_OCR_USE_TEXTLINE_ORIENTATION=true
PADDLE_STRUCTURE_USE_TABLE=true
PADDLE_STRUCTURE_USE_FORMULA=false
OCR_GPU_DEVICES=all
OCR_GPU_DEVICE=gpu:0
